---
// src/layouts/Layout.astro
import '../styles/global.css';

interface Props {
  	title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		<meta name="description" content="Grand Bar – Distribuidora premium de bebidas. Vinos, espumantes y espirituosas de las mejores marcas." />
	</head>
	<body>
		<slot />
	</body>
</html>