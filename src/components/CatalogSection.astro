---
interface Variant {
    label: string;
    price: number;
}

interface Product {
    name: string;
    detail?: string;
    price: number;
    promo?: string;
    variants?: Variant[];
    image?: string;
}

interface Brand {
    name: string;
    note?: string;
    products: Product[];
}

interface Props {
    id: string;
    label: string;
    brands: Brand[];
}

const { id, label, brands } = Astro.props;

const fmt = (n: number) =>
    '$' + n.toLocaleString('es-AR', {
        minimumFractionDigits: 0,
        maximumFractionDigits: 0
    });
---

<section class="catalog-section" id={id} data-category={id}>
    <!-- Section header -->
    <div class="section-header">
        <span class="section-rule"></span>
        <h2 class="section-title">{label}</h2>
        <span class="section-rule"></span>
    </div>

    {brands.map(brand => (
        <div class="brand-block">
            <div class="brand-header">
                <h3 class="brand-name">{brand.name}</h3>

                {brand.note && (
                    <span class="brand-note">{brand.note}</span>
                )}
            </div>

            <div class="products-grid">
                {brand.products.map(product => (
                    <article class="product-card">

                        {product.image && (
                            <div class="product-image-wrapper">
                                <img
                                    src={product.image}
                                    alt={product.name}
                                    class="product-image"
                                    loading="lazy"
                                />
                            </div>
                        )}

                        <div class="product-content">

                            <div class="product-top">
                                <h4 class="product-name">
                                    {product.name}
                                </h4>

                                {product.detail && (
                                    <span class="product-detail">
                                        {product.detail}
                                    </span>
                                )}
                            </div>

                            <div class="product-price">
                                {fmt(product.price)}
                            </div>

                            {product.variants && product.variants.length > 0 && (
                                <div class="product-variants">
                                    {product.variants.map(v => (
                                        <div class="variant-row">
                                            <span class="variant-label">
                                                {v.label}
                                            </span>

                                            <span class="variant-price">
                                                {fmt(v.price)}
                                            </span>
                                        </div>
                                    ))}
                                </div>
                            )}

                            {product.promo && (
                                <div class="product-promo">
                                    {product.promo}
                                </div>
                            )}

                        </div>
                    </article>
                ))}
            </div>
        </div>
    ))}
</section>

<style>
    .catalog-section {
        padding: 3.5rem 0 1rem;
    }

    /* ───────────────── SECTION HEADER ───────────────── */

    .section-header {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        margin-bottom: 2.5rem;
    }

    .section-rule {
        flex: 1;
        height: 1px;
        background-color: #c9c0b0;
    }

    .section-title {
        font-family: 'DM Mono', 'Courier New', monospace;
        font-size: 0.65rem;
        font-weight: 400;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: #a0956e;
        white-space: nowrap;
    }

    /* ───────────────── BRAND BLOCK ───────────────── */

    .brand-block {
        margin-bottom: 3rem;
    }

    .brand-header {
        display: flex;
        align-items: baseline;
        gap: 0.75rem;
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid #e5e0d5;
    }

    .brand-name {
        font-family: 'EB Garamond', Georgia, serif;
        font-size: 1.4rem;
        font-weight: 500;
        letter-spacing: 0.05em;
        color: #0d0d0d;
    }

    .brand-note {
        font-family: 'DM Mono', 'Courier New', monospace;
        font-size: 0.6rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: #999;
    }

    /* ───────────────── PRODUCTS GRID ───────────────── */

    .products-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
        gap: 1.2rem;
    }

    /* ───────────────── PRODUCT CARD ───────────────── */

    .product-card {
        background-color: #f5f0e8;
        border: 1px solid #e5e0d5;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition:
            transform 0.25s ease,
            box-shadow 0.25s ease,
            background-color 0.25s ease;
    }

    .product-card:hover {
        background-color: #fff;
        transform: translateY(-4px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.06);
    }

    /* ───────────────── IMAGE ───────────────── */

    .product-image-wrapper {
        width: 100%;
        aspect-ratio: 1 / 1;
        overflow: hidden;
        background: #eee7dc;
    }

    .product-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: transform 0.4s ease;
    }

    .product-card:hover .product-image {
        transform: scale(1.05);
    }

    /* ───────────────── CONTENT ───────────────── */

    .product-content {
        padding: 1.1rem 1.1rem 1rem;
        display: flex;
        flex-direction: column;
        gap: 0.7rem;
        flex: 1;
    }

    .product-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 0.5rem;
    }

    .product-name {
        font-family: 'EB Garamond', Georgia, serif;
        font-size: 1.05rem;
        font-weight: 500;
        line-height: 1.3;
        color: #1a1a1a;
        flex: 1;
    }

    .product-detail {
        font-family: 'DM Mono', 'Courier New', monospace;
        font-size: 0.55rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #aaa;
        white-space: nowrap;
        padding-top: 0.2rem;
    }

    /* ───────────────── PRICE ───────────────── */

    .product-price {
        font-family: 'EB Garamond', Georgia, serif;
        font-size: 1.8rem;
        font-weight: 600;
        color: #0d0d0d;
        line-height: 1;
        letter-spacing: -0.03em;
    }

    /* ───────────────── VARIANTS ───────────────── */

    .product-variants {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
        border-top: 1px dashed #ddd7cc;
        padding-top: 0.6rem;
    }

    .variant-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .variant-label {
        font-family: 'DM Mono', 'Courier New', monospace;
        font-size: 0.6rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #888;
    }

    .variant-price {
        font-family: 'EB Garamond', Georgia, serif;
        font-size: 0.95rem;
        color: #555;
    }

    /* ───────────────── PROMO ───────────────── */

    .product-promo {
        margin-top: auto;
        border-top: 1px solid #e5e0d5;
        padding-top: 0.6rem;

        font-family: 'DM Mono', 'Courier New', monospace;
        font-size: 0.58rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;

        color: #a0956e;
    }

    /* ───────────────── RESPONSIVE ───────────────── */

    @media (max-width: 768px) {
        .products-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .product-price {
            font-size: 1.4rem;
        }
    }

    @media (max-width: 480px) {
        .products-grid {
            grid-template-columns: 1fr;
        }
    }
</style>