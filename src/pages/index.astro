<!-- ══════════════════════════════════════════
    SCRIPTS
══════════════════════════════════════════ -->
<script>
	// ─── NAV SCROLL ──────────────────────────────────────────────
	const navbar = document.getElementById('navbar');
	window.addEventListener('scroll', () => {
		navbar?.classList.toggle('scrolled', window.scrollY > 30);
	});

	// ─── CART STATE ───────────────────────────────────────────────
	interface CartItem {
		id: string;
		name: string;
		price: number;
		image: string;
		qty: number;
	}

	let cart: CartItem[] = [];
	const WA_NUMBER = '5493512345678'; // CAMBIAR por número real

	function saveCart() {
		try { localStorage.setItem('grandbar_cart', JSON.stringify(cart)); } catch {}
	}
	function loadCart() {
		try {
		const stored = localStorage.getItem('grandbar_cart');
		if (stored) cart = JSON.parse(stored);
		} catch {}
	}
	loadCart();

	// ─── CART UI ──────────────────────────────────────────────────
	const cartDrawer = document.getElementById('cart-drawer')!;
	const cartOverlay = document.getElementById('cart-overlay')!;
	const cartCount = document.getElementById('cart-count')!;
	const cartItems = document.getElementById('cart-items')!;
	const cartEmpty = document.getElementById('cart-empty')!;
	const cartFooter = document.getElementById('cart-footer')!;
	const cartTotal = document.getElementById('cart-total')!;

	function openCart() {
		cartDrawer.classList.add('open');
		cartOverlay.classList.add('open');
		document.body.style.overflow = 'hidden';
	}
	function closeCart() {
		cartDrawer.classList.remove('open');
		cartOverlay.classList.remove('open');
		document.body.style.overflow = '';
	}

	document.getElementById('cart-btn')?.addEventListener('click', openCart);
	document.getElementById('close-cart')?.addEventListener('click', closeCart);
	cartOverlay.addEventListener('click', closeCart);

	function renderCart() {
		const totalItems = cart.reduce((s, i) => s + i.qty, 0);
		cartCount.textContent = String(totalItems);
		cartCount.classList.toggle('visible', totalItems > 0);

		if (cart.length === 0) {
		cartEmpty.style.display = 'flex';
		cartFooter.style.display = 'none';
		cartItems.innerHTML = '';
		return;
		}
		cartEmpty.style.display = 'none';
		cartFooter.style.display = 'flex';

		cartItems.innerHTML = cart.map(item => `
		<div class="cart-item" data-id="${item.id}">
			<img class="cart-item-img" src="${item.image}" alt="${item.name}"
			onerror="this.src='/bebidas/placeholder.webp'; this.onerror=null;" />
			<div>
			<p class="cart-item-name">${item.name}</p>
			<p class="cart-item-price">$${(item.price * item.qty).toLocaleString('es-AR')}</p>
			</div>
			<div class="cart-item-controls">
			<div class="qty-control">
				<button class="qty-btn" data-action="dec" data-id="${item.id}">−</button>
				<span class="qty-num">${item.qty}</span>
				<button class="qty-btn" data-action="inc" data-id="${item.id}">+</button>
			</div>
			<button class="remove-item" data-id="${item.id}">Quitar</button>
			</div>
		</div>
		`).join('');

		const total = cart.reduce((s, i) => s + i.price * i.qty, 0);
		cartTotal.textContent = `$${total.toLocaleString('es-AR')}`;

		// QTY buttons
		cartItems.querySelectorAll('.qty-btn').forEach(btn => {
		btn.addEventListener('click', () => {
			const id = (btn as HTMLElement).dataset.id!;
			const action = (btn as HTMLElement).dataset.action!;
			const item = cart.find(i => i.id === id);
			if (!item) return;
			if (action === 'inc') item.qty++;
			else if (action === 'dec') {
			item.qty--;
			if (item.qty <= 0) cart = cart.filter(i => i.id !== id);
			}
			saveCart();
			renderCart();
		});
		});

		// Remove buttons
		cartItems.querySelectorAll('.remove-item').forEach(btn => {
		btn.addEventListener('click', () => {
			const id = (btn as HTMLElement).dataset.id!;
			cart = cart.filter(i => i.id !== id);
			saveCart();
			renderCart();
		});
		});
	}
	renderCart();

	// ─── ADD TO CART ──────────────────────────────────────────────
	document.querySelectorAll<HTMLButtonElement>('.add-to-cart').forEach(btn => {
		btn.addEventListener('click', () => {
		const { id, name, price, image } = btn.dataset as Record<string, string>;
		const existing = cart.find(i => i.id === id);
		if (existing) {
			existing.qty++;
		} else {
			cart.push({ id, name, price: Number(price), image, qty: 1 });
		}
		saveCart();
		renderCart();

		// Visual feedback
		btn.classList.add('added');
		const original = btn.innerHTML;
		btn.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Agregado`;
		setTimeout(() => {
			btn.innerHTML = original;
			btn.classList.remove('added');
		}, 1400);
		});
	});

	// ─── CLEAR CART ───────────────────────────────────────────────
	document.getElementById('clear-cart-btn')?.addEventListener('click', () => {
		cart = [];
		saveCart();
		renderCart();
	});

	// ─── SEND ORDER VIA WA ────────────────────────────────────────
	document.getElementById('send-order-btn')?.addEventListener('click', () => {
		if (cart.length === 0) return;
		const lines = cart.map(i => `• ${i.name} x${i.qty} — $${(i.price * i.qty).toLocaleString('es-AR')}`);
		const total = cart.reduce((s, i) => s + i.price * i.qty, 0);
		const msg = `🛒 *Pedido Grand Bar*\n\n${lines.join('\n')}\n\n*Total estimado: $${total.toLocaleString('es-AR')}*\n\n¡Hola! Quiero confirmar este pedido.`;
		window.open(`https://wa.me/${WA_NUMBER}?text=${encodeURIComponent(msg)}`, '_blank');
	});

	// ─── CONTACT FORM VIA WA ──────────────────────────────────────
	document.getElementById('contact-send-btn')?.addEventListener('click', () => {
		const name = (document.getElementById('cf-name') as HTMLInputElement).value.trim();
		const phone = (document.getElementById('cf-phone') as HTMLInputElement).value.trim();
		const msg = (document.getElementById('cf-msg') as HTMLTextAreaElement).value.trim();
		if (!name && !msg) return;
		const text = `Hola Grand Bar! Soy ${name || '(sin nombre)'}${phone ? ` (${phone})` : ''}.\n\n${msg}`;
		window.open(`https://wa.me/${WA_NUMBER}?text=${encodeURIComponent(text)}`, '_blank');
	});

	// ─── CATALOG FILTER ───────────────────────────────────────────
	const cards = document.querySelectorAll<HTMLElement>('.product-card');
	const noResults = document.getElementById('no-results')!;
	let activeCategory = 'Todos';
	let searchQuery = '';

	function filterProducts() {
		let visible = 0;
		cards.forEach(card => {
		const cat = card.dataset.category!;
		const name = card.dataset.name!;
		const brand = card.dataset.brand!;
		const matchCat = activeCategory === 'Todos' || cat === activeCategory;
		const matchSearch = !searchQuery || name.includes(searchQuery) || brand.includes(searchQuery);
		const show = matchCat && matchSearch;
		card.classList.toggle('hidden', !show);
		if (show) visible++;
		});
		noResults.style.display = visible === 0 ? 'block' : 'none';
	}

	document.querySelectorAll<HTMLElement>('.filter-btn').forEach(btn => {
		btn.addEventListener('click', () => {
		document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
		btn.classList.add('active');
		activeCategory = btn.dataset.category!;
		filterProducts();
		});
	});

	const searchInput = document.getElementById('search-input') as HTMLInputElement;
	searchInput.addEventListener('input', () => {
		searchQuery = searchInput.value.toLowerCase().trim();
		filterProducts();
	});
</script>